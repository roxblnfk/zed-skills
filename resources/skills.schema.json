{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/roxblnfk/zed-skills/master/resources/skills.schema.json",
    "title": "skills.json",
    "description": "Project manifest for the `skills` CLI (schema v2). Unknown top-level keys are fatal.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "type": "string"
        },
        "target": {
            "description": "Directory (relative to the project root) skills are synced into.",
            "type": "string",
            "minLength": 1,
            "default": ".agents/skills"
        },
        "aliases": {
            "description": "Additional link locations mirroring the target (symlink on POSIX, junction on Windows). Must be unique and must not equal the target.",
            "type": "array",
            "items": {
                "type": "string",
                "minLength": 1
            },
            "uniqueItems": true
        },
        "lock-file": {
            "description": "Lockfile location (relative to the project root). Must stay inside the project root and must not equal the target, an alias or skills.json itself.",
            "type": "string",
            "minLength": 1,
            "default": "skills.lock"
        },
        "trusted": {
            "description": "Trusted vendor patterns: 'vendor/package' or 'vendor/*'.",
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^[^/]+/[^/]+$"
            }
        },
        "trusted-replace": {
            "description": "When true, only the project 'trusted' list applies (builtin list and direct-dependency trust are disabled).",
            "type": "boolean",
            "default": false
        },
        "discovery": {
            "description": "Gates the recursive-fallback skill locator.",
            "type": "boolean",
            "default": false
        },
        "local": {
            "description": "Local provider toggles.",
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "composer": {
                    "type": "boolean"
                },
                "npm": {
                    "description": "Reserved.",
                    "type": "boolean"
                },
                "go": {
                    "description": "Reserved.",
                    "type": "boolean"
                }
            }
        },
        "sources": {
            "description": "Explicit donor sources: by-package (github/gitlab), by-url (http/zip) or a local directory (dir).",
            "type": "array",
            "items": {
                "oneOf": [
                    { "$ref": "#/$defs/sourceByPackage" },
                    { "$ref": "#/$defs/sourceByUrl" },
                    { "$ref": "#/$defs/sourceByDir" }
                ]
            }
        },
        "remote": {
            "deprecated": true,
            "description": "Renamed to sources; read as a deprecated alias.",
            "type": "array",
            "items": {
                "oneOf": [
                    { "$ref": "#/$defs/sourceByPackage" },
                    { "$ref": "#/$defs/sourceByUrl" },
                    { "$ref": "#/$defs/sourceByDir" }
                ]
            }
        },
        "audit": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "mode": {
                    "description": "off = audit stage skipped; warn = blocking findings render as warnings; block = any blocking finding aborts the sync (exit 3).",
                    "enum": ["off", "warn", "block"],
                    "default": "off"
                },
                "pipeline": {
                    "description": "Ordered auditor chain. Absent = a single 'static' entry; [] = no auditors. 'llm' and 'http' are reserved for a future release.",
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                            "use": {
                                "enum": ["static", "llm", "http"]
                            },
                            "on-fail": {
                                "description": "Caps this auditor's effective severity: warn downgrades blocks, block upgrades warnings.",
                                "enum": ["warn", "block"]
                            },
                            "model": {
                                "description": "llm only.",
                                "type": "string",
                                "minLength": 1
                            },
                            "url": {
                                "description": "http only.",
                                "type": "string",
                                "minLength": 1
                            }
                        },
                        "required": ["use"],
                        "allOf": [
                            {
                                "if": {
                                    "properties": {
                                        "use": {
                                            "const": "static"
                                        }
                                    }
                                },
                                "then": {
                                    "properties": {
                                        "model": false,
                                        "url": false
                                    }
                                }
                            },
                            {
                                "if": {
                                    "properties": {
                                        "use": {
                                            "const": "llm"
                                        }
                                    }
                                },
                                "then": {
                                    "properties": {
                                        "url": false
                                    }
                                }
                            },
                            {
                                "if": {
                                    "properties": {
                                        "use": {
                                            "const": "http"
                                        }
                                    }
                                },
                                "then": {
                                    "properties": {
                                        "model": false
                                    }
                                }
                            }
                        ]
                    }
                }
            }
        },
        "path-from-root": {
            "description": "Monorepo re-anchor: relative path with plain segments only (no '.'/'..').",
            "type": "string",
            "minLength": 1
        }
    },
    "not": {
        "required": ["sources", "remote"]
    },
    "$defs": {
        "sourceByPackage": {
            "type": "object",
            "description": "Donor source entry for name-based adapters (github, gitlab).",
            "additionalProperties": false,
            "required": ["from", "package"],
            "properties": {
                "from": {
                    "enum": ["github", "gitlab"]
                },
                "package": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Repository identifier, e.g. owner/repo (GitLab: group/subgroup/project)."
                },
                "host": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Self-hosted instance (GitHub Enterprise, self-hosted GitLab). Absent = the public host."
                },
                "ref": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Version pin: tag, branch or commit SHA. Absent = latest stable tag, falling back to the default branch HEAD."
                },
                "skills": {
                    "description": "Tri-state: absent/null = all skills; [] = donor registered, pulls nothing; non-empty = allowlist matched by canonical skill name.",
                    "type": ["array", "null"],
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "sourceByUrl": {
            "type": "object",
            "description": "Donor source entry for URL-based adapters (http, zip).",
            "additionalProperties": false,
            "required": ["from", "url"],
            "properties": {
                "from": {
                    "enum": ["http", "zip"]
                },
                "url": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Archive URL to download."
                },
                "sha256": {
                    "type": "string",
                    "description": "Optional integrity hash of the downloaded archive."
                },
                "skills": {
                    "description": "Tri-state: absent/null = all skills; [] = donor registered, pulls nothing; non-empty = allowlist matched by canonical skill name.",
                    "type": ["array", "null"],
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "sourceByDir": {
            "type": "object",
            "description": "Donor source entry for the path-based adapter (dir): a local directory declared as an explicit donor.",
            "additionalProperties": false,
            "required": ["from", "path"],
            "properties": {
                "from": {
                    "enum": ["dir"]
                },
                "path": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Directory path, relative to the project root and confined to it: absolute paths (including Windows drive letters) and escaping '..' segments are rejected."
                },
                "package": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Optional donor vendor-name override."
                },
                "skills": {
                    "description": "Tri-state: absent/null = all skills; [] = donor registered, pulls nothing; non-empty = allowlist matched by canonical skill name.",
                    "type": ["array", "null"],
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        }
    }
}
